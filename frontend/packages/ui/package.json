{
  "name": "@damnit-frontend/ui",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.21.0",
  "author": {
    "name": "European XFEL",
    "email": "da@xfel.eu"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles.ts"
  },
  "imports": {
    "#src/*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx"
    ],
    "#tests/*": [
      "./tests/*",
      "./tests/*.ts",
      "./tests/*.tsx"
    ]
  },
  "sideEffects": [
    "./src/styles.ts",
    "**/*.css"
  ],
  "scripts": {
    "lint:eslint": "eslint . --max-warnings 0",
    "lint:prettier": "prettier --check --cache .",
    "lint:tsc": "tsc -b --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@apollo/client": "catalog:graphql",
    "@glideapps/glide-data-grid": "catalog:components",
    "@glideapps/glide-data-grid-cells": "catalog:components",
    "@mantine/core": "catalog:components",
    "@mantine/form": "catalog:components",
    "@mantine/hooks": "catalog:components",
    "@monaco-editor/react": "catalog:components",
    "@reduxjs/toolkit": "catalog:redux",
    "@tabler/icons-react": "catalog:components",
    "clsx": "catalog:frontend",
    "dayjs": "catalog:frontend",
    "graphql": "catalog:graphql",
    "graphql-ws": "catalog:graphql",
    "lodash": "catalog:frontend",
    "mantine-contextmenu": "catalog:components",
    "mantine-datatable": "catalog:components",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "react-laag": "catalog:frontend",
    "react-plotly.js": "catalog:components",
    "react-redux": "catalog:redux",
    "react-router": "catalog:frontend"
  },
  "devDependencies": {
    "@apollo/client": "catalog:graphql",
    "@damnit-frontend/config": "workspace:*",
    "@glideapps/glide-data-grid": "catalog:components",
    "@glideapps/glide-data-grid-cells": "catalog:components",
    "@mantine/core": "catalog:components",
    "@mantine/form": "catalog:components",
    "@mantine/hooks": "catalog:components",
    "@monaco-editor/react": "catalog:components",
    "@reduxjs/toolkit": "catalog:redux",
    "@tabler/icons-react": "catalog:components",
    "@types/lodash": "catalog:types",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@types/react-plotly.js": "catalog:types",
    "@vitejs/plugin-react": "catalog:tooling",
    "@vitest/browser": "catalog:testing",
    "@vitest/browser-playwright": "catalog:testing",
    "clsx": "catalog:frontend",
    "dayjs": "catalog:frontend",
    "eslint": "catalog:linting",
    "graphql": "catalog:graphql",
    "graphql-ws": "catalog:graphql",
    "lodash": "catalog:frontend",
    "mantine-contextmenu": "catalog:components",
    "mantine-datatable": "catalog:components",
    "playwright": "catalog:testing",
    "postcss": "catalog:tooling",
    "prettier": "catalog:linting",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "react-laag": "catalog:frontend",
    "react-plotly.js": "catalog:components",
    "react-redux": "catalog:redux",
    "react-router": "catalog:frontend",
    "typescript": "catalog:tooling",
    "vite": "catalog:tooling",
