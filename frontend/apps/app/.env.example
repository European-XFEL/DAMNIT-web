# Copy this file to .env.local and adjust as needed.

# Backend API the dev server proxies to. Required: the dev server will
# not start without it.
# Shared dev host: http://max-exfl463.desy.de:8000
VITE_API=http://localhost:8000

# App base path (optional, defaults to "/").
VITE_BASE_URL=/app/

# Dev server port (optional, defaults to 5173).
# VITE_PORT=5173

# mTLS, only needed when VITE_API is https. Provide all three or none.
# VITE_MTLS_CA=
# VITE_MTLS_CERT=
# VITE_MTLS_KEY=

# Analytics (optional, off by default).
# VITE_UMAMI_ENABLED=false
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_HOST_URL=
