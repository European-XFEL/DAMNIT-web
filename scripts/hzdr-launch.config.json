{
  "repositories": {
    "damnitWeb": "",
    "asapoHarness": "asapo-for-hzdr-damnit",
    "kafkaBroker": "kafka-broker-docker",
    "labfrog": "labfrog",
    "labfrogSqliteTools": "labfrog-sqlite-tools-repo",
    "planetWatchdog": "planet-watchdog"
  },
  "ports": {
    "api": 8000,
    "gui": 5173,
    "asapoBroker": 8765,
    "kafka": 9092,
    "mongo": 27018,
    "web":8005
  },
  "auth": {
    "mode": "none"
  },
  "connections": {
    "shotcounter": {
      "zmq": "tcp://127.0.0.1:5555",
      "topic": "shotcounter.shots"
    },
    "kafka": {
      "bootstrap": "127.0.0.1:9092",
      "topic": "planet.watchdog.events",
      "topics": {
        "watchdog": "planet.watchdog.events"
      }
    },
    "asapo": {
      "broker": "http://127.0.0.1:8765"
    },
    "mongo": {
      "uri": "mongodb://root:mypasswd@localhost:27018/?authSource=admin",
      "database": "shotsheet",
      "collection": "shots",
      "shotField": "shot_number"
    }
  },
  "emulator": {
    "sourceKey": "hzdr-emulator",
    "experimentId": "",
    "shotCount": 6,
    "shotIncrement": 1,
    "eventsDir": "",
    "outputDir": "",
    "startAsapoBroker": false,
    "startKafka": false,
    "startLabfrog": false,
    "openFlowMonitor": false
  },
  "flowMonitor": {
    "receivers": {
      "laserData": true,
      "watchdog": true,
      "mongo": true
    },
    "producers": {
      "shotcounter": {
        "enabled": true,
        "tkeys": [
          { "value": "draco01", "label": "Draco01", "description": "primary shot notice TKEY" },
          { "value": "draco02", "label": "Draco02", "description": "LLI watcher fanout TKEY" },
          { "value": "draco04", "label": "Draco04", "description": "LLI watcher fanout TKEY" },
          { "value": "draco07", "label": "Draco07", "description": "PNG original attachment TKEY" },
          { "value": "draco08", "label": "Draco08", "description": "LLI watcher fanout TKEY" }
        ]
      },
      "laserData": {
        "enabled": true
      },
      "watchdog": {
        "enabled": true,
        "watchers": [
          { "value": "png-originals", "label": "PNG originals", "description": "set1_*_original.png with Draco01/Draco07 ZMQ attachment" },
          { "value": "dummy-analysis", "label": "Dummy analysis", "description": "script parser rule for generic dummy analysis files" },
          { "value": "lli-parser", "label": "LLI parser", "description": "LLI ToolResult CSV parser with Draco02/04/08 topics" },
          { "value": "tps-quick", "label": "TPS quick", "description": "simple TPS parser for particle spectrum text output" }
        ]
      },
      "mongo": {
        "enabled": true,
        "updates_damnit_sqlite": false
      }
    }
  }
}
