# Auth mode configuration, required to run the API without --path.
# Copy this file to api/.env and fill in the values.

# OAuth (XFEL SSO)
DW_API_AUTH__CLIENT_ID=
DW_API_AUTH__CLIENT_SECRET=
DW_API_AUTH__SERVER_METADATA_URL=

# Signs session cookies. Any non-empty random string.
DW_API_SESSION_SECRET=

# MyMdC, for real proposal data.
# Credentials: https://in.xfel.eu/metadata/oauth/applications
DW_API_MYMDC__CLIENT_ID=
DW_API_MYMDC__CLIENT_SECRET=
DW_API_MYMDC__EMAIL=
DW_API_MYMDC__TOKEN_URL=
DW_API_MYMDC__BASE_URL=
