# HZDR DAMNIT-web configuration.
#
# Use this for labfrog/VLS-style MongoDB plus LDAP/Helmholtz deployment wiring.
# Copy to api/.env for local development, then fill in real URIs/credentials.

DW_API_AUTH__MODE=ldap
DW_API_DEBUG=true
DW_API_LOG_LEVEL=DEBUG

# HZDR should use local file/Mongo/VLS providers, not MyMdC.
DW_API_METADATA__PROVIDER=mongo
DW_API_METADATA__MONGO_URI=mongodb://localhost:27018
DW_API_METADATA__MONGO_DATABASE=damnit_web
DW_API_METADATA__MONGO_COLLECTION=hzdr_sources

# Curated LabFrog campaign SQLite snapshots (read-only) used by the Link Records
# page for the campaign picker / record reference. Point this at the
# curated_files/ directory produced by labfrog-sqlite-tools. Keep it next to the
# sources file. Unset/missing => Link Records shows no curated campaigns.
# DW_API_METADATA__LABFROG_CURATED_DIR=/bigdata/share/kristin/experiments/curated_files

# User-facing words returned by GET /config/runtime.
DW_API_DEPLOYMENT__PROFILE=hzdr
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME=source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME_PLURAL=sources
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL=Source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL_PLURAL=Sources
DW_API_DEPLOYMENT__TERMINOLOGY__COLLECTION_LABEL=HZDR sources
DW_API_DEPLOYMENT__TERMINOLOGY__USES_PROPOSALS=false
DW_API_DEPLOYMENT__TERMINOLOGY__USES_MYMDC=false

# Map stable source keys to DAMNIT folders. The key is still passed through the
# current GraphQL `proposal` input for compatibility.
DW_API_DAMNIT__PATHS_BY_PROPOSAL__hzdr=.

# Live shot feed from a separate MongoDB collection (for example an existing
# labfrog container at localhost:27018).
DW_API_METADATA__MONGO_SHOTS_DATABASE=shotsheet
DW_API_METADATA__MONGO_SHOTS_COLLECTION=shots

# Leave this blank when all documents in the shot collection belong to the
# selected HZDR source. Set it to source_key/instrument/etc. when present.
DW_API_METADATA__MONGO_SHOTS_SOURCE_FIELD=
DW_API_METADATA__MONGO_SHOTS_NUMBER_FIELD=shot_number
DW_API_METADATA__MONGO_SHOTS_FIRED_AT_FIELD=fired_at

# Default source shown when only the shot collection is configured.
DW_API_METADATA__MONGO_DEFAULT_SOURCE_KEY=hzdr-labfrog
DW_API_METADATA__MONGO_DEFAULT_SOURCE_TITLE=HZDR labfrog shots
DW_API_METADATA__MONGO_DEFAULT_DAMNIT_PATH=.

# Context builder writes per-source, per-user context files locally on the API
# host. Point this at a backed-up/shared path for deployment.
DW_API_CONTEXT_WORKSPACE__STORAGE=local
DW_API_CONTEXT_WORKSPACE__ROOT=../.generated/context-workspaces
DW_API_CONTEXT_WORKSPACE__WRITE_ENABLED=true

# Optional LDAP settings when testing real LDAP.
# DW_API_AUTH__LDAP__SERVER_URL=ldaps://ldap.example.org
# DW_API_AUTH__LDAP__BIND_DN_TEMPLATE=uid={username},ou=people,dc=example,dc=org
# DW_API_AUTH__LDAP__USER_SEARCH_BASE=ou=people,dc=example,dc=org
