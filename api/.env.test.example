# Generated local test configuration.
#
# Use this when you want a clean smoke test without labfrog, VLS MongoDB,
# MyMdC, or external auth services.

DW_API_AUTH__MODE=ldap
DW_API_DEBUG=true
DW_API_LOG_LEVEL=DEBUG

# Generated by:
#   uv run python scripts/generate-hzdr-example.py
DW_API_METADATA__PROVIDER=local
DW_API_METADATA__SOURCES_FILE=../.generated/hzdr-example/hzdr_sources.json

# User-facing words returned by GET /config/runtime.
DW_API_DEPLOYMENT__PROFILE=hzdr-test
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME=source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME_PLURAL=sources
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL=Source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL_PLURAL=Sources
DW_API_DEPLOYMENT__TERMINOLOGY__COLLECTION_LABEL=Generated HZDR sources
DW_API_DEPLOYMENT__TERMINOLOGY__USES_PROPOSALS=false
DW_API_DEPLOYMENT__TERMINOLOGY__USES_MYMDC=false

# Internal compatibility key used by current GraphQL/database paths.
DW_API_DAMNIT__PATHS_BY_PROPOSAL__hzdr-example=../.generated/hzdr-example/damnit/hzdr-example

# Context builder saves per-source, per-user context.py files here.
DW_API_CONTEXT_WORKSPACE__STORAGE=local
DW_API_CONTEXT_WORKSPACE__ROOT=../.generated/context-workspaces
DW_API_CONTEXT_WORKSPACE__WRITE_ENABLED=true
