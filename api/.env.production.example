# Production environment template for DAMNIT-web-hzdr API.
#
# Copy to .env and fill in real values before deploying.
# Lines starting with # are comments. All DW_API_* vars use __ as the
# nested delimiter (e.g. DW_API_AUTH__MODE sets settings.auth.mode).
#
# Structured JSON logging is active automatically when DW_API_DEBUG=false.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

DW_API_DEBUG=false
DW_API_LOG_LEVEL=INFO

# Path to the DAMNIT data directory for this deployment.
# Must contain the campaign subdirectories and spool/ layout.
DW_API_DAMNIT_PATH=/data/damnit/hzdr

# SQLite database for internal API state (sessions, etc.)
DW_API_DB_PATH=/data/damnit/hzdr/dw_api.sqlite

# A long random string.  Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DW_API_SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# LDAP — set server_url to enable the LDAP login form.
DW_API_AUTH__MODE=ldap
DW_API_AUTH__LDAP__SERVER_URL=ldaps://ldap.hzdr.de
DW_API_AUTH__LDAP__BIND_DN_TEMPLATE=uid={username},ou=people,dc=hzdr,dc=de
DW_API_AUTH__LDAP__USER_SEARCH_BASE=ou=people,dc=hzdr,dc=de
DW_API_AUTH__LDAP__USER_SEARCH_FILTER=(uid={username})
DW_API_AUTH__LDAP__DISPLAY_NAME_ATTRIBUTE=displayName
DW_API_AUTH__LDAP__EMAIL_ATTRIBUTE=mail
DW_API_AUTH__LDAP__TIMEOUT=5

# ---------------------------------------------------------------------------
# Metadata / source catalog
# ---------------------------------------------------------------------------

# "local" reads from hzdr_sources.json on disk (written by hzdr-hdf5-builder).
# "mongo" reads from a live MongoDB collection.
DW_API_METADATA__PROVIDER=local
DW_API_METADATA__SOURCES_FILE=/data/damnit/hzdr/hzdr_sources.json

# MongoDB (used when PROVIDER=mongo, or for the shots side-channel).
# DW_API_METADATA__MONGO_URI=mongodb://localhost:27017
# DW_API_METADATA__MONGO_DATABASE=damnit
# DW_API_METADATA__MONGO_COLLECTION=hzdr_sources

# ---------------------------------------------------------------------------
# Durable spool consumer (ASAPO)
# ---------------------------------------------------------------------------

# Set ENABLED=true to start the background ASAPO consumer inside the API process.
# The consumer writes events to spool_dir/<campaign>/events.jsonl and acks
# the broker only after each write is fsync'd.
DW_API_HZDR_SPOOL__ENABLED=false
DW_API_HZDR_SPOOL__BROKER_URL=http://asapo-broker.hzdr.de:8765
DW_API_HZDR_SPOOL__CAMPAIGN=Solenoid_Beamline_Tests_01.2025
DW_API_HZDR_SPOOL__CONSUMER_GROUP=damnit
DW_API_HZDR_SPOOL__SPOOL_DIR=/data/damnit/hzdr/spool/asapo
DW_API_HZDR_SPOOL__POLL_INTERVAL=2.0
DW_API_HZDR_SPOOL__BATCH_SIZE=10

# ---------------------------------------------------------------------------
# Durable spool consumer (Kafka — PLANET-Watchdog / shotcounter triggers)
# ---------------------------------------------------------------------------

# Set ENABLED=true to start the background Kafka consumer inside the API process.
# It consumes the hzdr-event-v1 trigger envelope from TOPICS with manual offset
# commit (enable_auto_commit=False) and commits only after each event is fsync'd
# to spool_dir/<campaign>/<filename>. Point the builder at that file with
# --trigger-jsonl.
DW_API_HZDR_KAFKA_SPOOL__ENABLED=false
DW_API_HZDR_KAFKA_SPOOL__BOOTSTRAP_SERVERS=kafka.hzdr.de:9092
DW_API_HZDR_KAFKA_SPOOL__TOPICS=["hzdr.solenoid.triggers"]
DW_API_HZDR_KAFKA_SPOOL__CAMPAIGN=Solenoid_Beamline_Tests_01.2025
DW_API_HZDR_KAFKA_SPOOL__CONSUMER_GROUP=damnit-kafka
DW_API_HZDR_KAFKA_SPOOL__SPOOL_DIR=/data/damnit/hzdr/spool/kafka
DW_API_HZDR_KAFKA_SPOOL__FILENAME=trigger.jsonl
DW_API_HZDR_KAFKA_SPOOL__POLL_INTERVAL=2.0
DW_API_HZDR_KAFKA_SPOOL__POLL_TIMEOUT_MS=1000
DW_API_HZDR_KAFKA_SPOOL__BATCH_SIZE=10

# ---------------------------------------------------------------------------
# Flow monitor health probes (GET /config/health)
# ---------------------------------------------------------------------------

DW_API_HZDR_HEALTH__ASAPO_STATUS_URL=http://asapo-broker.hzdr.de:8765/api/status
DW_API_HZDR_HEALTH__KAFKA_BOOTSTRAP=kafka.hzdr.de:9092
DW_API_HZDR_HEALTH__MONGO_URI=mongodb://localhost:27017
DW_API_HZDR_HEALTH__TIMEOUT=2.0

# ---------------------------------------------------------------------------
# Uvicorn
# ---------------------------------------------------------------------------

DW_API_UVICORN__HOST=127.0.0.1
DW_API_UVICORN__PORT=8000
DW_API_UVICORN__RELOAD=false
# SSL — uncomment and point at real cert/key files for HTTPS.
# DW_API_UVICORN__SSL_CERTFILE=/etc/ssl/certs/damnit.crt
# DW_API_UVICORN__SSL_KEYFILE=/etc/ssl/private/damnit.key

# ---------------------------------------------------------------------------
# Deployment terminology (shown in UI)
# ---------------------------------------------------------------------------

DW_API_DEPLOYMENT__PROFILE=hzdr
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME=source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME_PLURAL=sources
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL=Source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL_PLURAL=Sources
DW_API_DEPLOYMENT__TERMINOLOGY__COLLECTION_LABEL=HZDR sources
DW_API_DEPLOYMENT__TERMINOLOGY__USES_PROPOSALS=false
DW_API_DEPLOYMENT__TERMINOLOGY__USES_MYMDC=false
