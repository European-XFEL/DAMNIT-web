# Pilot production environment for DAMNIT-web-hzdr API.
#
# This is the concrete .env for the FIRST REAL DEPLOYMENT TEST (pilot
# campaign `Pilot_Verification_07.2026`, decided 2026-07-02). It is a
# variant of .env.production.example with the Kafka spool consumer turned on
# and pointed at the pilot campaign; ASAPO stays disabled (LaserData/ASAPO is
# explicitly excluded from this pilot).
#
# Copy to .env and fill in real values before deploying:
#   cp .env.pilot.example .env
#   # DW_API_SESSION_SECRET: python -c "import secrets; print(secrets.token_hex(32))"
#
# All DW_API_* vars use __ as the nested delimiter (e.g. DW_API_AUTH__MODE
# sets settings.auth.mode). Structured JSON logging is active automatically
# when DW_API_DEBUG=false.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

DW_API_DEBUG=false
DW_API_LOG_LEVEL=INFO

DW_API_DAMNIT_PATH=/data/damnit/hzdr
DW_API_DB_PATH=/data/damnit/hzdr/dw_api.sqlite

# A long random string. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DW_API_SESSION_SECRET=<REPLACE with generated secret>

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

DW_API_AUTH__MODE=ldap
DW_API_AUTH__LDAP__SERVER_URL=ldaps://ldap.fz-rossendorf.de:636
DW_API_AUTH__LDAP__BIND_DN_TEMPLATE=uid={username},ou=users,ou=FZR-NIS,ou=it,o=fsr,dc=de
DW_API_AUTH__LDAP__USER_SEARCH_BASE=ou=users,ou=FZR-NIS,ou=it,o=fsr,dc=de
DW_API_AUTH__LDAP__USER_SEARCH_FILTER=(uid={username})
DW_API_AUTH__LDAP__DISPLAY_NAME_ATTRIBUTE=displayName
DW_API_AUTH__LDAP__EMAIL_ATTRIBUTE=mail
# The dept LDAP schema doesn't define memberOf -- leave empty, groups come back as [].
DW_API_AUTH__LDAP__GROUPS_ATTRIBUTE=
DW_API_AUTH__LDAP__TIMEOUT=5

# ---------------------------------------------------------------------------
# Metadata / source catalog
# ---------------------------------------------------------------------------

DW_API_METADATA__PROVIDER=local
DW_API_METADATA__SOURCES_FILE=/data/damnit/hzdr/hzdr_sources.json
DW_API_METADATA__LABFROG_CURATED_DIR=/data/damnit/hzdr/curated_files


# ---------------------------------------------------------------------------
# MediaWiki campaign links / optional live probe
# ---------------------------------------------------------------------------

DW_API_HZDR_WIKI__BASE_URL=https://athene.fz-rossendorf.de/fwk
DW_API_HZDR_WIKI__NAMESPACE=FWKT
DW_API_HZDR_WIKI__FETCH_TIMEOUT=5.0
# Optional for GET /metadata/hzdr/sources/{source_key}/wiki?fetch=true against login-required wikis.
# Keep real values only in deployed .env or instance config; never commit them.
# DW_API_HZDR_WIKI__COOKIE_HEADER=wiki_session=...; wikiUserID=...
# DW_API_HZDR_WIKI__AUTHORIZATION_HEADER=Bearer ...
# ---------------------------------------------------------------------------
# Durable spool consumer (ASAPO) -- EXCLUDED from this pilot
# ---------------------------------------------------------------------------

# ASAPO/LaserData is explicitly out of scope for Pilot_Verification_07.2026
# (fixed decision, 2026-07-02). Keep disabled for the whole pilot; re-enable
# only under master-plan Phase 5 (LaserData / ASAPO sidecar, deferred).
DW_API_HZDR_SPOOL__ENABLED=false
DW_API_HZDR_SPOOL__CAMPAIGN=Pilot_Verification_07.2026
DW_API_HZDR_SPOOL__CONSUMER_GROUP=damnit
DW_API_HZDR_SPOOL__SPOOL_DIR=/data/damnit/hzdr/spool/asapo
DW_API_HZDR_SPOOL__POLL_INTERVAL=2.0
DW_API_HZDR_SPOOL__BATCH_SIZE=10
DW_API_HZDR_SPOOL__BROKER_KIND=http
DW_API_HZDR_SPOOL__BROKER_URL=http://asapo-broker.hzdr.de:8765

# ---------------------------------------------------------------------------
# Durable spool consumer (Kafka -- DAQ File Watchdog / shotcounter triggers)
# ---------------------------------------------------------------------------

# The pilot's primary data-transfer path. Broker runs on this same VM
# (fwkt-webapps.fz-rossendorf.de:9092 externally) -- this API talks to it
# over localhost.
DW_API_HZDR_KAFKA_SPOOL__ENABLED=true
DW_API_HZDR_KAFKA_SPOOL__BOOTSTRAP_SERVERS=localhost:9092
# Canonical topics -- see kafka-broker-docker/topics.env.
DW_API_HZDR_KAFKA_SPOOL__TOPICS=["draco.trigger","planet.watchdog.events"]
DW_API_HZDR_KAFKA_SPOOL__CAMPAIGN=Pilot_Verification_07.2026
DW_API_HZDR_KAFKA_SPOOL__CONSUMER_GROUP=damnit-kafka
DW_API_HZDR_KAFKA_SPOOL__SPOOL_DIR=/data/damnit/hzdr/spool/kafka
DW_API_HZDR_KAFKA_SPOOL__FILENAME=trigger.jsonl
DW_API_HZDR_KAFKA_SPOOL__POLL_INTERVAL=2.0
DW_API_HZDR_KAFKA_SPOOL__POLL_TIMEOUT_MS=1000
DW_API_HZDR_KAFKA_SPOOL__BATCH_SIZE=10

# ---------------------------------------------------------------------------
# Flow monitor health probes (GET /config/health)
# ---------------------------------------------------------------------------

# ASAPO probe stays pointed at the harness URL but is moot while the ASAPO
# spool consumer above is disabled for the pilot.
DW_API_HZDR_HEALTH__ASAPO_STATUS_URL=http://asapo-broker.hzdr.de:8765/api/status
DW_API_HZDR_HEALTH__KAFKA_BOOTSTRAP=localhost:9092
DW_API_HZDR_HEALTH__MONGO_URI=mongodb://localhost:27017
DW_API_HZDR_HEALTH__TIMEOUT=2.0

# ---------------------------------------------------------------------------
# Uvicorn
# ---------------------------------------------------------------------------

DW_API_UVICORN__HOST=127.0.0.1
DW_API_UVICORN__PORT=8000
DW_API_UVICORN__RELOAD=false

# ---------------------------------------------------------------------------
# Deployment terminology (shown in UI)
# ---------------------------------------------------------------------------

DW_API_DEPLOYMENT__PROFILE=hzdr
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME=source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME_PLURAL=sources
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL=Source
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL_PLURAL=Sources
DW_API_DEPLOYMENT__TERMINOLOGY__COLLECTION_LABEL=HZDR sources
DW_API_DEPLOYMENT__TERMINOLOGY__USES_PROPOSALS=false
DW_API_DEPLOYMENT__TERMINOLOGY__USES_MYMDC=false

# ---------------------------------------------------------------------------
# Pilot HDF5 builder invocation (run manually after events are flowing;
# not read from this .env -- documented here for the operator)
# ---------------------------------------------------------------------------
#
# python api/scripts/hzdr-hdf5-builder.py \
#     --experiment-id Pilot_Verification_07.2026 \
#     --labfrog-sqlite /data/damnit/hzdr/Pilot_Verification_07.2026/Pilot_Verification_07.2026.sqlite \
#     --trigger-jsonl /data/damnit/hzdr/spool/kafka/Pilot_Verification_07.2026/trigger.jsonl \
#     --output-nexus /data/damnit/hzdr/Pilot_Verification_07.2026/Pilot_Verification_07.2026.nxs
