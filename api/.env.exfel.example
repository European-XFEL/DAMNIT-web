# EXFEL/DAMNIT-web configuration sketch.
#
# Copy this to api/.env for local testing against EXFEL services, or set the
# same variables in deployment.

DW_API_AUTH__MODE=oauth
DW_API_METADATA__PROVIDER=mymdc

# User-facing words returned by GET /config/runtime.
DW_API_DEPLOYMENT__PROFILE=exfel
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME=proposal
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_NAME_PLURAL=proposals
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL=Proposal
DW_API_DEPLOYMENT__TERMINOLOGY__IDENTITY_LABEL_PLURAL=Proposals
DW_API_DEPLOYMENT__TERMINOLOGY__COLLECTION_LABEL=Proposals
DW_API_DEPLOYMENT__TERMINOLOGY__USES_PROPOSALS=true
DW_API_DEPLOYMENT__TERMINOLOGY__USES_MYMDC=true

# OAuth/OIDC settings.
DW_API_AUTH__CLIENT_ID=
DW_API_AUTH__CLIENT_SECRET=
DW_API_AUTH__SERVER_METADATA_URL=

# MyMdC settings.
DW_API_MYMDC__CLIENT_ID=
DW_API_MYMDC__CLIENT_SECRET=
DW_API_MYMDC__EMAIL=
DW_API_MYMDC__TOKEN_URL=
DW_API_MYMDC__BASE_URL=
